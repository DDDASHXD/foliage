{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "foliage",
  "version": "0.0.3",
  "identifier": "dev.skxv.foliage",
  "build": {
    "beforeDevCommand": "pnpm run dev:server",
    "devUrl": "http://127.0.0.1:3000/launcher",
    "beforeBuildCommand": "node scripts/tauri-before-build.mjs",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "foliage",
        "url": "/launcher.html",
        "width": 900,
        "height": 600,
        "resizable": true,
        "dragDropEnabled": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/node/**/*",
      "resources/foliage-relay/**/*",
      "resources/foliage-server/bin/**/*",
      "resources/foliage-server/lib/**/*",
      "resources/foliage-server/src/**/*",
      "resources/foliage-server/package.json",
      "resources/foliage-server/node_modules/**/*"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
